general {
  lock_cmd = hyprlock
  before_sleep_cmd = swaylock --color 000000 --show-keyboard-layout --indicator-idle-visible
  ignore_dbus_inhibit = false
  ignore_systemd_inhibit = false
}

listener {
  timeout = 3600
  on-timeout = pidof swaylock || swaylock --color 000000 --show-keyboard-layout --indicator-idle-visible
}

listener {
  timeout = 4000
  on-timeout = hyprctl dispatch dpms off
}
